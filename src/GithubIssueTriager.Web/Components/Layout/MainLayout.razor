@inherits LayoutComponentBase

@* Teams purple-blue gives the app its own identity instead of the default
   Fluent accent every generated app starts with. System mode follows the
   OS so the UI doesn't fight whatever the user already prefers. *@
<FluentDesignTheme Mode="DesignThemeModes.System" OfficeColor="OfficeColor.Teams" StorageName="theme" />

<FluentLayout>
    <FluentHeader>
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="width:100%">
            <FluentIcon Value="@(new Icons.Regular.Size24.BranchCompare())" Color="Color.FillInverse" />
            <FluentLabel Typo="Typography.Header" Color="Color.FillInverse">GitHub Issue Auto-Triager</FluentLabel>
        </FluentStack>
    </FluentHeader>

    <FluentStack Class="main" Orientation="Orientation.Horizontal" Width="100%">
        <NavMenu />

        <FluentBodyContent Class="body-content">
            <div class="content">
                @Body
            </div>
        </FluentBodyContent>
    </FluentStack>
</FluentLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
