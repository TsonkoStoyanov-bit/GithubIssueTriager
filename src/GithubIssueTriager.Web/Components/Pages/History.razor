@page "/history"

<PageTitle>History</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="justify-content:space-between;">
    <FluentLabel Typo="Typography.PageTitle" Class="page-title">
        Triage history
        @if (_records is { Count: > 0 })
        {
            <FluentBadge Appearance="Appearance.Neutral">@_records.Count</FluentBadge>
        }
    </FluentLabel>
    <FluentButton Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size16.ArrowClockwise())" Disabled="@(_records is null)" @onclick="Load">
        Refresh
    </FluentButton>
</FluentStack>

<FluentLabel Typo="Typography.Body" Class="page-subtitle" Style="display:block;margin:4px 0 20px;">
    Every issue the triage pipeline has processed, newest first.
</FluentLabel>

@if (_records is null)
{
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
        <FluentProgressRing Style="width:24px;height:24px" />
        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading history…</FluentLabel>
    </FluentStack>
}
else if (_records.Count == 0)
{
    <FluentMessageBar Intent="MessageIntent.Info" Title="No history yet">
        Triage an issue from the Triage page first.
    </FluentMessageBar>
}
else
{
    <FluentCard Class="form-card">
        <div style="overflow-x:auto">
        <FluentDataGrid Items="@_records.AsQueryable()" Pagination="@_pagination" GridTemplateColumns="1.3fr 1.5fr 0.4fr 2fr 1.3fr 1.1fr 1.6fr" Style="min-width:900px;width:100%">
            <TemplateColumn Title="Triaged at" Sortable="true" SortBy="@_byDate">
                @FormatTimestamp(context.TriagedAt)
            </TemplateColumn>
            <PropertyColumn Property="@(r => r.Repo)" Title="Repo" Sortable="true" />
            <PropertyColumn Property="@(r => r.IssueNumber)" Title="#" Sortable="true" />
            <PropertyColumn Property="@(r => r.Title)" Title="Title" />

            <TemplateColumn Title="Category" Sortable="true" SortBy="@_byCategory">
                <FluentBadge Class="@CategoryClass(context.Category)">@context.Category · @context.Confidence.ToString("P0")</FluentBadge>
            </TemplateColumn>

            <TemplateColumn Title="Priority" Sortable="true" SortBy="@_byPriority">
                <FluentBadge Class="@PriorityClass(context.Priority)">@context.Priority · @context.PriorityScore</FluentBadge>
            </TemplateColumn>

            <TemplateColumn Title="Labels">
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="4" Style="flex-wrap:wrap">
                    @foreach (var label in context.Labels ?? new())
                    {
                        <FluentBadge Class="@(label.Contains("review") ? "lbl-review" : "lbl-default")">@label</FluentBadge>
                    }
                </FluentStack>
            </TemplateColumn>
        </FluentDataGrid>
        </div>

        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12" Style="margin-top:14px;flex-wrap:wrap">
            <FluentPaginator State="@_pagination" />
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                @_records.Count total
            </FluentLabel>
        </FluentStack>
    </FluentCard>
}

@code {
    private List<TriageRecord>? _records;

    private readonly PaginationState _pagination = new() { ItemsPerPage = 10 };

    private readonly GridSort<TriageRecord> _byDate = GridSort<TriageRecord>.ByDescending(r => r.TriagedAt);
    private readonly GridSort<TriageRecord> _byCategory = GridSort<TriageRecord>.ByAscending(r => r.Category);
    private readonly GridSort<TriageRecord> _byPriority = GridSort<TriageRecord>.ByAscending(r => r.PriorityScore);

    // TriagedAt is stored as a round-trip ("o") UTC string. Render it as a short, readable
    // local date-time; if it somehow doesn't parse, fall back to the raw value rather than blank.
    private static string FormatTimestamp(string iso) =>
        DateTimeOffset.TryParse(iso, System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.RoundtripKind, out var dt)
            ? dt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
            : iso;

    [Inject] private TriageApiClient Api { get; set; } = default!;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _records = null;
        _records = await Api.GetHistoryAsync(100);
    }

    private static readonly HashSet<string> KnownCategories =
        new(StringComparer.OrdinalIgnoreCase) { "bug", "feature", "question", "documentation" };

    private static string CategoryClass(string category) =>
        KnownCategories.Contains(category) ? $"cat-{category.ToLowerInvariant()}" : "cat-other";

    private static string PriorityClass(string priority) => $"prio-{priority.ToLowerInvariant()}";
}
