@page "/settings"

<PageTitle>Settings</PageTitle>

<FluentLabel Typo="Typography.PageTitle">Configuration</FluentLabel>
<FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="display:block;margin:4px 0 20px;">
    Read from / written back to <code>appsettings.json</code> on the Api host (the <code>Triage</code> section). Changes apply live — no restart.
</FluentLabel>

@if (_settings is null)
{
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
        <FluentProgressRing Style="width:24px;height:24px" />
        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading settings…</FluentLabel>
    </FluentStack>
}
else
{
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Style="max-width:560px">

        <FluentCard Class="form-card">
            <div class="section-header">
                <FluentIcon Value="@(new Icons.Regular.Size20.DocumentText())" Color="Color.Accent" />
                <FluentLabel Typo="Typography.PaneHeader">Issue source</FluentLabel>
            </div>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                <FluentRadioGroup TValue="string" Name="issueSource" @bind-Value="_settings.IssueSource" Label="Issue source" Orientation="Orientation.Horizontal">
                    <FluentRadio Value="@("Local")">Local JSON</FluentRadio>
                    <FluentRadio Value="@("Remote")">Remote (GitHub API)</FluentRadio>
                </FluentRadioGroup>
                <FluentTextField @bind-Value="_settings.LocalJsonPath" Label="Local JSON folder (relative to Api content root)" Style="width:100%" />
            </FluentStack>
        </FluentCard>

        <FluentCard Class="form-card">
            <div class="section-header">
                <FluentIcon Value="@(new Icons.Regular.Size20.Cloud())" Color="Color.Accent" />
                <FluentLabel Typo="Typography.PaneHeader">GitHub API</FluentLabel>
            </div>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                <FluentTextField @bind-Value="_settings.GitHubOwner" Label="Default owner" Placeholder="anthropics" Style="width:100%" />
                <FluentTextField @bind-Value="_settings.GitHubRepo" Label="Default repo" Placeholder="claude-code" Style="width:100%" />
                <FluentNumberField TValue="int" @bind-Value="_settings.GitHubIssueNumber" Label="Default issue number" Style="width:100%" />
                <FluentTextField @bind-Value="_settings.GitHubToken" Label="Personal access token" TextFieldType="TextFieldType.Password" Style="width:100%" />
            </FluentStack>
        </FluentCard>

        <FluentCard Class="form-card">
            <div class="section-header">
                <FluentIcon Value="@(new Icons.Regular.Size20.Flash())" Color="Color.Accent" />
                <FluentLabel Typo="Typography.PaneHeader">Priority thresholds</FluentLabel>
            </div>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="display:block;margin-bottom:10px;">Minimum summed score required for each level.</FluentLabel>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                <FluentNumberField TValue="int" @bind-Value="_settings.PriorityCritical" Label="Critical ≥" Style="width:100%" />
                <FluentNumberField TValue="int" @bind-Value="_settings.PriorityHigh" Label="High ≥" Style="width:100%" />
                <FluentNumberField TValue="int" @bind-Value="_settings.PriorityMedium" Label="Medium ≥" Style="width:100%" />
            </FluentStack>
        </FluentCard>

        <FluentCard Class="form-card">
            <div class="section-header">
                <FluentIcon Value="@(new Icons.Regular.Size20.ShieldCheckmark())" Color="Color.Accent" />
                <FluentLabel Typo="Typography.PaneHeader">Classifier safety net</FluentLabel>
            </div>
            <FluentNumberField TValue="double" @bind-Value="_settings.LowConfidenceReviewThreshold" Label="Flag for human review when confidence is below" Step="0.05" Min="0" Max="1" Style="width:100%" />
        </FluentCard>

        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
            <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size16.Save())" Disabled="@_saving" @onclick="Save">
                Save settings
            </FluentButton>
            @if (_saving)
            {
                <FluentProgressRing Style="width:20px;height:20px" />
            }
        </FluentStack>

        @if (_savedMessage is not null)
        {
            <FluentMessageBar Intent="MessageIntent.Success" Title="Saved">@_savedMessage</FluentMessageBar>
        }
    </FluentStack>
}

@code {
    private TriageSettingsDto? _settings;
    private bool _saving;
    private string? _savedMessage;

    [Inject] private TriageApiClient Api { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _settings = await Api.GetSettingsAsync();
    }

    private async Task Save()
    {
        if (_settings is null) return;
        _saving = true;
        _savedMessage = null;

        var updated = await Api.SaveSettingsAsync(_settings);
        _saving = false;

        if (updated is not null)
        {
            _settings = updated;
            _savedMessage = "Settings saved to appsettings.json on the Api host.";
        }
    }
}
